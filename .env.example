# OpenAI or google AI model provider
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Flags and models
EMAIL_AGENT_USE_LLM=false
EMAIL_AGENT_USE_LLM_CLASSIFICATION=false
EMAIL_AGENT_USE_LLM_SUMMARY=true
EMAIL_AGENT_LLM_PROVIDER=gemini
EMAIL_AGENT_LANGUAGE=en
EMAIL_AGENT_MODEL=gemini-2.5-flash
EMAIL_AGENT_LLM_MAX_EMAILS=6
EMAIL_AGENT_LLM_MAX_SNIPPET_CHARS=120
EMAIL_AGENT_LLM_MAX_BODY_CHARS=180
EMAIL_AGENT_LLM_INPUT_COST_PER_1K_TOKENS=0.00001
EMAIL_AGENT_LLM_OUTPUT_COST_PER_1K_TOKENS=0.00001

# Gmail integration
GMAIL_CREDENTIALS_FILE=./credentials.json
GMAIL_TOKEN_FILE=./data/auth/gmail_token.json

# WEB.DE integration
WEBDE_EMAIL=
WEBDE_PASSWORD=
WEBDE_IMAP_HOST=imap.web.de
WEBDE_IMAP_PORT=993
WEBDE_IMAP_FOLDERS=INBOX,Unbekannt

# App configuration
EMAIL_AGENT_ENV=development
EMAIL_AGENT_DATA_DIR=./data
