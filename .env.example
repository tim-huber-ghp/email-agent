# OpenAI or google AI model provider
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Flags and models
EMAIL_AGENT_USE_LLM=false
EMAIL_AGENT_LLM_PROVIDER=gemini
EMAIL_AGENT_LANGUAGE=en
EMAIL_AGENT_MODEL=gemini-2.5-flash

# Gmail integration
GMAIL_CREDENTIALS_FILE=./credentials.json
GMAIL_TOKEN_FILE=./data/auth/gmail_token.json

# App configuration
EMAIL_AGENT_ENV=development
EMAIL_AGENT_DATA_DIR=./data
